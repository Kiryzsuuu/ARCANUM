# ============================================================
#  ARCANUM — Environment Configuration
#  Copy file ini menjadi .env dan isi nilai yang sesuai
# ============================================================

# MongoDB connection string
# Dapatkan dari: https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/arcanum?retryWrites=true&w=majority

# Secret key untuk enkripsi session (isi string acak yang panjang)
# Contoh generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=<generate_a_long_random_hex_string>

# Port server (default 3000)
PORT=3000
